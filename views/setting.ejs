<html lang="en">
<%- include('partials/head.ejs')%>
    <title>Setting</title>

    <body>
        <%- include('partials/header.ejs')%>

            <div class="settings-container">

                <div class="back-to-dashboard" onclick="window.location.href='/profile/<%= user._id %>'"
                    style="cursor: pointer;">
                    <img src="/public/img/icon/Icon13.png" alt="">
                    <p>Back to Dashboard</p>
                </div>

                <div class="settings-top-bar">
                    <% if (query && query.success==='name' ) { %>
                        <div
                            style="background:#f0fdf4;border:1px solid #86efac;color:#16a34a;border-radius:10px;padding:12px 16px;font-size:14px;margin-bottom:16px;">
                            Имя успешно изменено.
                        </div>
                        <% } %>
                            <% if (query && query.success==='password' ) { %>
                                <div
                                    style="background:#f0fdf4;border:1px solid #86efac;color:#16a34a;border-radius:10px;padding:12px 16px;font-size:14px;margin-bottom:16px;">
                                    Пароль успешно изменён.
                                </div>
                                <% } %>
                                    <% if (query && query.error==='wrong' ) { %>
                                        <div
                                            style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:10px;padding:12px 16px;font-size:14px;margin-bottom:16px;">
                                            Неверный текущий пароль.
                                        </div>
                                        <% } %>
                                            <% if (query && query.error==='confirm' ) { %>
                                                <div
                                                    style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:10px;padding:12px 16px;font-size:14px;margin-bottom:16px;">
                                                    Новые пароли не совпадают.
                                                </div>
                                                <% } %>
                                                    <% if (query && query.error==='short' ) { %>
                                                        <div
                                                            style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:10px;padding:12px 16px;font-size:14px;margin-bottom:16px;">
                                                            Пароль минимум 6 символов.
                                                        </div>
                                                        <% } %>
                                                            <% if (query && query.error==='name' ) { %>
                                                                <div
                                                                    style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:10px;padding:12px 16px;font-size:14px;margin-bottom:16px;">
                                                                    Имя минимум 2 символа.
                                                                </div>
                                                                <% } %>
                                                                    <div class="title-area">
                                                                        <h1>Settings</h1>
                                                                        <p>Manage your account and preferences</p>
                                                                    </div>
                                                                    <button type="submit" form="nameForm"
                                                                        class="save-changes-btn"><svg width="20"
                                                                            height="20" viewBox="0 0 24 24" fill="none"
                                                                            stroke="currentColor" stroke-width="2"
                                                                            style="margin-right: 8px; vertical-align: middle;">
                                                                            <path
                                                                                d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z">
                                                                            </path>
                                                                            <polyline points="17 21 17 13 7 13 7 21">
                                                                            </polyline>
                                                                            <polyline points="7 3 7 8 15 8"></polyline>
                                                                        </svg>
                                                                        Save Changes</button>
                </div>

                <!-- <div class="settings-navigation">
                    <button class="nav-tab active">
                        <span class="tab-icon">👤</span> Profile
                    </button>
                    <button class="nav-tab">
                        <span class="tab-icon">🔒</span> Account
                    </button>
                </div> -->

                <div class="info-card">
                    <form id="nameForm" method="POST" action="/settings/update-name" class="personal-info-form"></form>
                    <h2 class="card-section-title">Personal Information</h2>

                    <div class="inputs-grid">
                        <div class="field-group">
                            <label class="field-label">Full Name</label>
                            <div class="input-control">
                                <span class="field-icon">👤</span>
                                <input type="text" name="name" value="<%=user.full_name%>" required>
                            </div>
                        </div>

                        <div class="field-group">
                            <label class="field-label">Email Address</label>
                            <div class="input-control readonly">
                                <span class="field-icon">✉️</span>
                                <input type="email" name="email" value="<%= user.email %>" readonly>
                            </div>
                            <p class="field-hint">Email cannot be changed</p>
                        </div>

                        <!-- <div class="field-group">
                                <label class="field-label">Phone Number</label>
                                <div class="input-control">
                                    <span class="field-icon">📞</span>
                                    <input type="text" name="phone" value="+7 (701) 234-5678">
                                </div>
                            </div>

                            <div class="field-group">
                                <label class="field-label">Date of Birth</label>
                                <div class="input-control">
                                    <span class="field-icon">📅</span>
                                    <input type="text" name="dob" value="04.07.2005">
                                </div>
                            </div> -->
                    </div>
                    </form>
                </div>

                <div class="info-card">
                    <form id="passwordForm" method="POST" action="/settings/update-password" class="personal-info-form">
                    </form>
                    <h2 class="card-section-title">Change Password</h2>

                    <div class="inputs-grid">
                        <div class="field-group">
                            <label class="field-label">Current Password</label>
                            <div class="input-control">
                                <img src="/public/img/icon/Lock.png" alt="">
                                <input type="password" name="currentPassword" required>
                            </div>
                        </div>

                        <div class="field-group">
                            <label class="field-label">New Password</label>
                            <div class="input-control">
                                <img src="/public/img/icon/Lock.png" alt="">
                                <input type="password" name="newPassword" required>
                            </div>
                        </div>

                        <div class="field-group">
                            <label class="field-label">Confirm New Password</label>
                            <div class="input-control">
                                <img src="/public/img/icon/Lock.png" alt="">
                                <input type="password" name="confirmPassword" required>
                            </div>
                        </div>
                    </div>
                    </form>
                </div>
            </div>

            <footer>
                <%- include('partials/footer.ejs')%>
            </footer>
            <%- include('partials/scripts.ejs')%>
    </body>

</html>