<html lang="en">
<head>
    <%- include('partials/head.ejs')%>
    <title>Sign In - Meditrace</title>
</head>
<body class="auth-page">
    <div class="page-wrapper">
        <div class="info-section">
            <div class="logo">Meditrace</div>
            <h1 class="main-title">Your Health<br>Records,<br><span class="gradient-text">Always Accessible</span></h1>
            <p class="description">Securely access your complete medical history from OLYMP, INVITRO, and all your healthcare providers in one place.</p>
            <ul class="features">
                <li>HIPAA Compliant & Secure</li>
                <li>AI-Powered Health Insights</li>
                <li>Access Anywhere, Anytime</li>
            </ul>
        </div>

        <div class="form-section">
            <div class="form-card">
                <h2>Welcome Back</h2>
                <p>Sign in to access your health dashboard</p>
                
                <form action="/api/signin" method="POST">
                    <div class="input-group">
                        <label>Email Address</label>
                        <div class="input-wrapper">
                            <i class="fa-regular fa-envelope input-icon"></i>
                            <input type="email" name="email" placeholder="you@example.com" required>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Password</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock input-icon"></i>
                            <input type="password" name="password" placeholder="••••••••" required>
                        </div>
                    </div>

                    <div class="extra-links">
                        <label><input type="checkbox" name="remember"> Remember me</label>
                        <a href="/forgot">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn-primary">Sign In</button>
                </form>

                <div class="form-footer">
                    Don't have an account? <a href="/regester">Sign up</a>
                </div>
                
                <div style="text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid #e5e7eb;">
                    <p style="font-size: 14px; color: #666; margin-bottom: 10px;">Or sign in with</p>
                    <a href="/api/auth/github" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: #24292e; color: white; text-decoration: none; border-radius: 8px; font-size: 14px;">
                        <i class="fab fa-github"></i> GitHub
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>