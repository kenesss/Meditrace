<html lang="ru" class="auth-login-html">
<head>
    <%- include('partials/head.ejs')%>
    <title>Вход — Meditrace</title>
</head>
<body class="auth-page auth-login">
    <div class="bg-shape shape-blue shape-top-right"></div>
    <div class="bg-shape shape-gray shape-bottom-left"></div>

    <main class="auth-login__container">
        <section class="auth-login__info">
            <h1 class="auth-login__logo">Meditrace</h1>

            <h2 class="auth-login__heading">
                Ваши медицинские<br>
                данные,<br>
                <span class="text-blue">Всегда доступны</span>
            </h2>

            <p class="auth-login__description">
                Безопасный доступ ко всей вашей медицинской истории из OLYMP, INVITRO и всех ваших медицинских учреждений в одном месте.
            </p>

            <ul class="auth-login__features">
                <li>Соответствие стандартам HIPAA и безопасность</li>
                <li>AI-инсайты о здоровье</li>
                <li>Доступ в любое время и в любом месте</li>
            </ul>
        </section>

        <section class="auth-login__form">
            <div class="auth-login__card">
                <h3 class="auth-login__title">С возвращением!</h3>
                <p class="auth-login__subtitle">Войдите, чтобы получить доступ к вашей панели здоровья</p>

                <form action="/api/signin" method="POST">
                    <div class="auth-login__group">
                        <label for="email">Адрес электронной почты</label>
                        <div class="auth-login__input has-left-icon">
                            <i class="fa-regular fa-envelope icon-left" aria-hidden="true"></i>
                            <input type="email" id="email" name="email" placeholder="you@example.com" required>
                        </div>
                    </div>

                    <div class="auth-login__group">
                        <label for="password">Пароль</label>
                        <div class="auth-login__input has-left-icon has-right-icon">
                            <i class="fa-solid fa-lock icon-left" aria-hidden="true"></i>
                            <input type="password" id="password" name="password" placeholder="••••••••" required>
                            <i class="fa-regular fa-eye icon-right js-password-toggle" role="button" tabindex="0" aria-label="Показать пароль"></i>
                        </div>
                    </div>

                    <div class="auth-login__meta">
                        <label class="auth-login__remember">
                            <input type="checkbox" name="remember">
                            <span>Запомнить меня</span>
                        </label>
                        <a href="/forgot" class="forgot-password">Забыли пароль?</a>
                    </div>

                    <button type="submit" class="auth-login__submit">Войти</button>
                </form>

                <div class="auth-login__footer">
                    <span>Нет аккаунта?</span>
                    <a href="/regester" class="login-link">Зарегистрироваться</a>
                </div>

                <% if (githubAuthEnabled) { %>
                <div class="auth-login__divider">
                    <p class="auth-login__divider-text">Или войдите с помощью</p>
                    <a href="/api/auth/github" class="auth-login__oauth">
                        <i class="fab fa-github" aria-hidden="true"></i>
                        <span>GitHub</span>
                    </a>
                </div>
                <% } %>
            </div>
        </section>
    </main>

    <script src="/js/password-toggle.js" defer></script>
</body>
</html>