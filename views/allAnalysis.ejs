<html lang="ru">
<%- include('partials/head.ejs')%>
  <title>Мои анализы — Meditrace</title>
  <body>
    <%- include('partials/header.ejs')%>
    <div class="meditrace-wrapper">
      <%- include('partials/menu.ejs')%>

      <% if (analyses && analyses.length > 0) { %>

        <script>
          window.MY_ANALYSES_DATA = <%- JSON.stringify(analyses) %>;
        </script>

        <div class="ma-page">

          <!-- ── Сайдбар со списком анализов ── -->
          <aside class="ma-sidebar">
            <span class="ma-sidebar-title">Список анализов</span>

            <div class="ma-search">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" id="searchInput" placeholder="Поиск по анализу…">
            </div>

            <% analyses.forEach(function(report, i) { %>
              <div class="ma-analysis-card" data-name="<%= (report.fileName || '').toLowerCase() %>">
                <div class="ma-card-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="5" y="2" width="14" height="20" rx="2"/>
                    <line x1="9" y1="7" x2="15" y2="7"/>
                    <line x1="9" y1="11" x2="15" y2="11"/>
                    <line x1="9" y1="15" x2="13" y2="15"/>
                  </svg>
                </div>
                <div class="ma-card-info">
                  <div class="ma-card-name"><%= report.fileName || report.testType || 'Анализ' %></div>
                  <div class="ma-card-meta">
                    <%= new Date(report.testDate || report.createdAt).toLocaleDateString('ru-RU') %>
                    &middot; <%= report.indicators.length %> показат.
                  </div>
                </div>
              </div>
            <% }); %>

            <!-- Кнопка загрузить ещё один анализ -->
            <a href="/pdf-upload-page/<%= user._id %>" class="ma-upload-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Загрузить ещё анализ
            </a>
          </aside>

          <!-- ── Основной контент ── -->
          <div class="ma-content">

            <div class="ma-detail-header">
              <div>
                <div class="ma-detail-title" id="maAnalysisTitle">—</div>
                <div class="ma-detail-meta"  id="maAnalysisMeta">—</div>
              </div>
              <div class="ma-tabs">
                <button class="ma-tab" id="tabChart">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                  График
                </button>
                <button class="ma-tab" id="tabTable">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg>
                  Таблица
                </button>
              </div>
            </div>

            <!-- График -->
            <div id="chartSection" class="ma-chart-card">
              <div class="ma-chart-topbar">
                <span class="ma-chart-label">Динамика показателя</span>
                <select id="indicatorSelect" class="ma-indicator-select"></select>
              </div>
              <div class="ma-chart-wrapper">
                <canvas id="maChart"></canvas>
              </div>
              <div class="ma-legend">
                <div class="ma-legend-item"><div class="ma-legend-dot" style="background:#22c55e"></div>В норме</div>
                <div class="ma-legend-item"><div class="ma-legend-dot" style="background:#ef4444"></div>Выше нормы</div>
                <div class="ma-legend-item"><div class="ma-legend-dot" style="background:#3b82f6"></div>Ниже нормы</div>
              </div>
            </div>

            <!-- Таблица -->
            <div id="tableSection" class="ma-table-card" style="display:none;">
              <table class="ma-table">
                <thead>
                  <tr>
                    <th>Показатель</th>
                    <th>Значение</th>
                    <th>Референс</th>
                    <th>Статус</th>
                  </tr>
                </thead>
                <tbody id="maTableBody"></tbody>
              </table>
            </div>

          </div>
        </div>

        <script src="/js/myAnalyses.js"></script>

      <% } else { %>

        <!-- Пустое состояние -->
        <div style="flex:1; display:flex; align-items:center; justify-content:center; padding:24px;">
          <div class="ma-empty">
            <div class="ma-empty-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="2" width="14" height="20" rx="2"/>
                <line x1="9" y1="7" x2="15" y2="7"/>
                <line x1="9" y1="11" x2="15" y2="11"/>
                <line x1="9" y1="15" x2="13" y2="15"/>
              </svg>
            </div>
            <h3>Нет загруженных анализов</h3>
            <p>Загрузите первый медицинский анализ, чтобы видеть графики и показатели</p>
            <a href="/pdf-upload-page/<%= user._id %>" class="ma-empty-upload-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              Загрузить анализ
            </a>
          </div>
        </div>

      <% } %>
    </div>

    <footer><%- include('partials/footer.ejs')%></footer>
    <!-- <%- include('partials/aiChat.ejs') %> -->
    <%- include('partials/scripts.ejs')%>
  </body>
</html>