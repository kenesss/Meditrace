<html lang="en">
<%- include('partials/head.ejs')%>
  <title>All Analyses - Meditrace</title>

  <body>
    <%- include('partials/header.ejs')%>
      <div class="meditrace-wrapper">
        <%- include('partials/menu.ejs')%>

          <div class="analyses-page">
            <!-- Поиск -->
            <div class="search-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input type="text" id="searchInput" placeholder="Поиск по названию или лаборатории"
                oninput="filterAnalyses()">
            </div>

            <% if(analyses && analyses.length> 0){ %>

              <!-- Список анализов -->
              <div class="analyses-list" id="analysesList">
                <% analyses.forEach(report=> { %>
                  <div class="analysis-item" data-name="<%= report.fileName.toLowerCase() %>">
                    <div class="analysis-left">
                      <div class="analysis-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round">
                          <rect x="5" y="2" width="14" height="20" rx="2"></rect>
                          <line x1="9" y1="7" x2="15" y2="7"></line>
                          <line x1="9" y1="11" x2="15" y2="11"></line>
                          <line x1="9" y1="15" x2="13" y2="15"></line>
                        </svg>
                      </div>
                      <div class="analysis-info">
                        <p class="analysis-name">
                          <%= report.fileName %>
                        </p>
                        <p class="analysis-meta">
                          <%= new Date(report.createdAt).toLocaleDateString('ru-RU') %>
                            <span class="meta-dot">·</span>
                            <%= report.indicators.length %> показателей
                        </p>
                      </div>
                    </div>

                    <div class="analysis-actions">
                      <a href="/analyses/<%= report._id %>" class="action-btn" title="Просмотр">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                          <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                      </a>
                      <a href="/analyses/<%= report._id %>/download" class="action-btn" title="Скачать">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="16 16 12 12 8 16"></polyline>
                          <line x1="12" y1="12" x2="12" y2="21"></line>
                          <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"></path>
                        </svg>
                      </a>
                      <button onclick="deleteAnalysis('<%= report._id %>')" class="action-btn action-btn--delete"
                        title="Удалить">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="3 6 5 6 21 6"></polyline>
                          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                          <path d="M10 11v6M14 11v6"></path>
                          <path d="M9 6V4h6v2"></path>
                        </svg>
                      </button>
                    </div>
                  </div>
                  <% }); %>
              </div>
              
              <!-- Шапка страницы -->
            <div class="analyses-header">
              <a href="/pdf-upload-page/<%= user._id %>" class="add-analysis-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Добавить анализ
              </a>
            </div>

              <!-- Нет результатов поиска -->
              <div class="no-search-result" id="noSearchResult" style="display:none;">
                <p>Ничего не найдено</p>
              </div>

              <% } else { %>

                <!-- Пустое состояние -->
                <div class="empty-state">
                  <div class="empty-icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.5"
                      stroke-linecap="round" stroke-linejoin="round">
                      <rect x="5" y="2" width="14" height="20" rx="2"></rect>
                      <line x1="9" y1="7" x2="15" y2="7"></line>
                      <line x1="9" y1="11" x2="15" y2="11"></line>
                      <line x1="9" y1="15" x2="13" y2="15"></line>
                    </svg>
                  </div>
                  <h3>Нет загруженных анализов</h3>
                  <p>Загрузите первый медицинский анализ чтобы начать</p>
                  <a href="/pdf-upload-page/<%= user._id %>" class="add-analysis-btn" style="margin-top: 20px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Добавить анализ
                  </a>
                </div>

                <% } %>
          </div>
      </div>
      <footer>
        <%- include('partials/footer.ejs')%>
      </footer>

      <script>
        async function deleteAnalysis(id) {
          if (!confirm('Удалить анализ?')) return;
          const res = await fetch('/api/analyses/' + id, { method: 'DELETE' });
          const data = await res.json();
          if (data.success) location.reload();
          else alert('Ошибка: ' + data.error);
        }
      </script>
      <%- include('partials/aiChat.ejs') %>
        <%- include('partials/scripts.ejs')%>
  </body>

</html>