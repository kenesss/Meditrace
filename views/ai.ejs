<html lang="en">
<%- include('partials/head.ejs')%>
    <title>Meditrace AI Assistant</title>

    <body>
        <%- include('partials/header.ejs')%>
            <div class="meditrace-wrapper">
                <%- include('partials/menu.ejs') %>
                    <main class="chat-container">
                        <div class="ai-chat-main">
                            <div class="chat-header">
                                <h2>Meditrace AI Assistant</h2>
                                <p>Ваш персональный помощник по здоровью</p>
                            </div>

                            <div id="chat-messages" class="chat-messages-area">
                                <div class="message ai-message">
                                    Здравствуйте! Я готов проанализировать ваши показатели или ответить на вопросы о
                                    здоровье. Чем могу помочь?
                                </div>
                            </div>

                            <form id="chat-form" class="chat-input-container">
                                <input type="text" id="user-input" placeholder="Напишите ваш вопрос здесь..." required
                                    autocomplete="off">
                                <button type="submit">
                                    <span>Отправить</span>
                                </button>
                            </form>
                        </div>
                    </main>
            </div>

            <footer>
                <%- include('partials/footer.ejs')%>
            </footer>

            <%- include('partials/scripts.ejs')%>
    </body>

</html>