<html lang="en">
<%- include('partials/head.ejs')%>
  <title>Goals - Meditrace</title>

  <body>
    <%- include('partials/header.ejs')%>

      <div class="meditrace-wrapper">
        <%- include('partials/menu.ejs')%>

          <div class="goals-page">

            <% if(analyses && analyses.length> 0){ %>

              <div class="goals-grid" id="goals-list">
                <% if (typeof goals !=='undefined' && goals.length> 0) { %>
                  <% goals.forEach(function(g) { %>
                    <div class="goal-card">

                      <!-- Шапка карточки -->
                      <div class="goal-card-header">
                        <h3 class="goal-title">
                          <%= g.direction==='below' ? 'Снизить' : 'Повысить' %>
                            <%= g.indicatorName %>
                        </h3>
                        <div class="goal-status-icon <%= g.achieved ? 'achieved' : 'pending' %>">
                          <% if (g.achieved) { %>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                              stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                            <% } %>
                        </div>
                      </div>

                      <!-- Описание -->
                      <p class="goal-description">
                        <%= g.direction==='below' ? 'Снизить' : 'Повысить' %>
                          <%= g.indicatorName.toLowerCase() %> до
                            <%= g.targetValue %>
                              <%= g.unit %>
                                <% if (g.note) { %><br><span class="goal-note">
                                    <%= g.note %>
                                  </span>
                                  <% } %>
                      </p>

                      <!-- Прогресс -->
                      <div class="goal-footer">
                        <span class="goal-days">
                          <% if (g.currentVal !==null) { %>
                            Сейчас: <%= g.currentVal %>
                              <%= g.unit %>
                                <% } else { %>
                                  Нет данных
                                  <% } %>
                        </span>
                        <span class="goal-percent <%= g.achieved ? 'goal-percent--done' : '' %>">
                          <%= g.progress !==null ? g.progress : 0 %>%
                        </span>
                      </div>
                      <div class="goal-progress-bar">
                        <div class="goal-progress-fill" style="width: <%= g.progress !== null ? g.progress : 0 %>%">
                        </div>
                      </div>

                      <!-- Кнопка удалить -->
                      <div class="goal-divider"></div>
                      <button class="goal-delete-btn" onclick="deleteGoal('<%= g._id %>')">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="3 6 5 6 21 6"></polyline>
                          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                          <path d="M10 11v6M14 11v6"></path>
                          <path d="M9 6V4h6v2"></path>
                        </svg>
                        Удалить
                      </button>
                    </div>
                    <% }); %>
                      <% } else { %>
                        <div class="goals-empty">
                          <p>Целей пока нет</p>
                          <p>Добавь цель — ИИ будет отслеживать твой прогресс</p>
                        </div>
                        <% } %>
              </div>

              <!-- Кнопка добавить — фиксированная внизу справа -->
              <button class="add-goal-fab" onclick="openGoalModal()">
                <span>+</span> Добавить цель
              </button>

              <% } else { %>
                <div class="goals-no-analyses">
                  <p>Нет загруженных анализов. Сначала загрузите анализ.</p>
                  <a href="/pdf-upload-page/<%= user._id %>" class="add-goal-fab" style="text-decoration:none;">
                    Загрузить анализ
                  </a>
                </div>
                <% } %>
          </div>
      </div>

      <!-- Модалка -->
      <div id="goalModal" class="modal-overlay">
        <div class="modal-box">
          <div class="modal-header">
            <h3>Новая цель</h3>
            <button class="modal-close" onclick="closeGoalModal()">✕</button>
          </div>
          <div class="modal-body">
            <div class="modal-field">
              <label>Показатель</label>
              <input id="goal-indicator" list="indicators-list" placeholder="напр. Холестерин">
              <datalist id="indicators-list">
                <option value="Гемоглобин">
                <option value="Холестерин">
                <option value="Глюкоза">
                <option value="Тестостерон">
                <option value="Кортизол">
                <option value="Лейкоциты">
                <option value="Эритроциты">
                <option value="Тромбоциты">
                <option value="СОЭ">
                <option value="Витамин D">
                <option value="Инсулин">
                <option value="Тиреотропин">
                <option value="АЛТ">
                <option value="АСТ">
                <option value="Креатинин">
              </datalist>
            </div>
            <div class="modal-row">
              <div class="modal-field">
                <label>Направление</label>
                <select id="goal-direction">
                  <option value="below">Снизить до</option>
                  <option value="above">Повысить до</option>
                </select>
              </div>
              <div class="modal-field">
                <label>Целевое значение</label>
                <input id="goal-target" type="number" step="0.01" placeholder="5.0">
              </div>
            </div>
            <div class="modal-field">
              <label>Единица измерения</label>
              <input id="goal-unit" placeholder="ммоль/л">
            </div>
            <div class="modal-field">
              <label>Заметка (необязательно)</label>
              <input id="goal-note" placeholder="напр. рекомендация врача">
            </div>
            <button class="modal-save-btn" onclick="saveGoal()">Сохранить цель</button>
          </div>
        </div>
      </div>

      <footer><%- include('partials/footer.ejs')%></footer>
      <script>
        function openGoalModal() { document.getElementById('goalModal').style.display = 'flex'; }
        function closeGoalModal() { document.getElementById('goalModal').style.display = 'none'; }
        async function saveGoal() {
          const indicator = document.getElementById('goal-indicator').value.trim();
          const direction = document.getElementById('goal-direction').value;
          const target = document.getElementById('goal-target').value;
          const unit = document.getElementById('goal-unit').value.trim();
          const note = document.getElementById('goal-note').value.trim();
          if (!indicator || !target) { alert('Заполните показатель и целевое значение'); return; }
          const params = new URLSearchParams(window.location.search);
          const member = params.get('member');
          const body = { indicatorName: indicator, targetValue: target, direction, unit, note };
          if (member) body.memberId = member;
          const res = await fetch('/api/goals', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          const data = await res.json();
          if (data.success) { closeGoalModal(); location.reload(); }
          else alert('Ошибка: ' + data.error);
        }
        async function deleteGoal(id) {
          if (!confirm('Удалить цель?')) return;
          const res = await fetch('/api/goals/' + id, { method: 'DELETE' });
          const data = await res.json();
          if (data.success) location.reload();
          else alert('Ошибка: ' + data.error);
        }
      </script>
      <%- include('partials/scripts.ejs')%>
  </body>

</html>