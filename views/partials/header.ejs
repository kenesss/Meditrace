<header>
  <% if(user._id && user.full_name.length> 0){ %>
    <div class="head-container">
      <div class="head-container-menu">
        <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Открыть меню">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
        <a href="#" class="logo"><img src="/public/img/icon/logo-2.png" alt=""></a>
      </div>

      <div class="head-logo-log">
        <div class="head-nav-log">
          <h1>
            <% if (activePage==='home') { %>Добро пожаловать, <%= user.full_name %>!
            <% } else if (activePage==='members') { %>Моя семья
            <% } else if (activePage==='analyses') { %>Мои анализы
            <% } else if (activePage==='comparison') { %>Сравнение анализов
            <% } else if (activePage==='ai') { %>AI-Ассистент
            <% } else if (activePage==='goals') { %>Цели здоровья
            <% } else if (activePage==='all-analyses') { %>Все анализы
            <% } else if (activePage==='settings') { %>Настройки профиля
            <% } else { %>Добро пожаловать, <%= user.full_name %>!
            <% } %>
          </h1>
          <p>
            <% if (activePage==='home') { %>Вот обзор вашего здоровья
            <% } else if (activePage==='members') { %>Управляйте медицинскими данными членов семьи
            <% } else if (activePage==='analyses') { %>Загружайте и просматривайте результаты анализов
            <% } else if (activePage==='comparison') { %>Отслеживайте динамику показателей здоровья
            <% } else if (activePage==='ai') { %>Анализ результатов и консультации по здоровью
            <% } else if (activePage==='goals') { %>Ставьте цели и отслеживайте прогресс
            <% } else if (activePage==='all-analyses') { %>Список всех ваших медицинских исследований
            <% } else { %>&nbsp;
            <% } %>
          </p>
        </div>
      </div>

      <div class="head-profile">
        <div class="profile-container">
          <div class="profile-trigger" id="profileTrigger">

            <div class="profile-avatar-circle">
              <% if (typeof activeMember !== 'undefined' && activeMember) { %>
                <%= activeMember.full_name[0].toUpperCase() %>
              <% } else { %>
                <%= user.full_name[0].toUpperCase() %>
              <% } %>
            </div>

            <div class="profile-trigger-info">
              <span class="profile-trigger-name">
                <% if (typeof activeMember !== 'undefined' && activeMember) { %>
                  <%= activeMember.full_name %>
                <% } else { %>
                  <%= user.full_name %>
                <% } %>
              </span>
              <span class="profile-trigger-role">
                <% if (typeof activeMember !== 'undefined' && activeMember) { %>
                  <%= activeMember.relationship %>
                <% } else { %>
                  Владелец
                <% } %>
              </span>
            </div>

            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" class="chevron-icon">
              <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>

          <div class="profile-dropdown" id="profileDropdown">
            <div class="dropdown-header">СМЕНИТЬ ПРОФИЛЬ</div>

            <div class="dropdown-user" onclick="switchProfile(null)" style="cursor:pointer">
              <div class="user-avatar" style="background: linear-gradient(135deg, #6366f1, #a855f7);">
                <%= user.full_name ? user.full_name[0].toUpperCase() : 'U' %>
              </div>
              <div class="user-info">
                <span class="user-name"><%= user.full_name %></span>
                <span class="user-role">Владелец</span>
              </div>
              <div class="status-icon <%= (typeof activeMemberId === 'undefined' || !activeMemberId) ? '' : 'unchecked' %>">✔</div>
            </div>

            <% if (typeof familyMembers !== 'undefined') { %>
              <% familyMembers.forEach(function(m) { %>
                <div class="dropdown-user" onclick="switchProfile('<%= m._id %>')" style="cursor:pointer">
                  <div class="user-info">
                    <span class="user-name"><%= m.full_name %></span>
                    <span class="user-role"><%= m.relationship %></span>
                  </div>
                  <div class="status-icon <%= (typeof activeMemberId !== 'undefined' && activeMemberId && activeMemberId.toString() === m._id.toString()) ? '' : 'unchecked' %>">✔</div>
                </div>
              <% }); %>
            <% } %>

            <div class="dropdown-divider"></div>
            <a href="/add-members/<%= user._id %>" class="manage-link">
              <img src="/public/img/icon/Settings-purple.png" alt="" class="manage-icon">
              Управление членами семьи
            </a>
          </div>
        </div>
      </div>
    </div>

  <% } else { %>
    <div class="landing-top-header">
      <a href="/" class="logo"><img src="/public/img/icon/logo-2.png" alt=""></a>
      <div class="auth-actions">
        <a href="/login" class="link-login">Войти</a>
        <a href="/regester" class="btn-register">Регистрация</a>
      </div>
    </div>
  <% } %>
</header>

<script>
  function switchProfile(memberId) {
    const url = new URL(window.location.href);
    if (memberId) {
      url.searchParams.set('member', memberId);
    } else {
      url.searchParams.delete('member');
    }
    window.location.href = url.toString();
  }

  (function () {
    const trigger  = document.getElementById('profileTrigger');
    const dropdown = document.getElementById('profileDropdown');
    if (!trigger || !dropdown) return;

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      dropdown.classList.toggle('show');
      const chevron = trigger.querySelector('.chevron-icon');
      if (chevron) {
        chevron.style.transform = dropdown.classList.contains('show') ? 'rotate(180deg)' : 'rotate(0deg)';
        chevron.style.transition = 'transform 0.2s';
      }
    });

    document.addEventListener('click', function (e) {
      if (!dropdown.contains(e.target) && !trigger.contains(e.target)) {
        dropdown.classList.remove('show');
        const chevron = trigger.querySelector('.chevron-icon');
        if (chevron) chevron.style.transform = 'rotate(0deg)';
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && dropdown.classList.contains('show')) {
        dropdown.classList.remove('show');
        const chevron = trigger.querySelector('.chevron-icon');
        if (chevron) chevron.style.transform = 'rotate(0deg)';
      }
    });
  })();
</script>
