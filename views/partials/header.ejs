<header>
    <% if(user._id && user.full_name.length> 0){
        %>
        <div class="head-container">
            <a href="/" class="logo">Meditrace</a>
            <div class="head-logo-log">
                <div class="head-nav-log">
                    <h1>Welcome back, <%=user.full_name%>!</h1>
                    <p>Mange your medical analysis and get AI-powered insights</p>
                </div>
            </div>
            <div class="head-profile">
                <div class="profile-container">
                    <div class="profile-trigger" id="profileTrigger">
                        <img src="/img/avatar.jpg" alt="" class="profile-img">
                        <p>
                            <%=user.full_name%>
                        </p>
                        <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg"
                            class="chevron-icon">
                            <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>

                    <div class="profile-dropdown" id="profileDropdown">
                        <div class="dropdown-header">SWITCH PROFILE</div>

                        <div class="dropdown-user active" onclick="switchProfile(null)" style="cursor:pointer">
                            <div class="user-avatar" style="background: linear-gradient(135deg, #6366f1, #a855f7);">
                                <%= user.full_name ? user.full_name[0].toUpperCase() : 'U' %>
                            </div>
                            <div class="user-info">
                                <span class="user-name"><%= user.full_name %></span>
                                <span class="user-role">Владелец</span>
                            </div>
                            <div class="status-icon <%= (typeof activeMemberId === 'undefined' || !activeMemberId) ? '' : 'unchecked' %>">✔</div>
                        </div>

                        <% if (typeof familyMembers !== 'undefined') { %>
                          <% familyMembers.forEach(function(m) { %>
                            <% const colors = {
                              purple: 'linear-gradient(135deg,#8B5CF6,#6366F1)',
                              pink:   'linear-gradient(135deg,#F472B6,#FB923C)',
                              cyan:   'linear-gradient(135deg,#22D3EE,#818CF8)',
                              blue:   'linear-gradient(135deg,#3B82F6,#60A5FA)',
                              green:  'linear-gradient(135deg,#34D399,#6EE7B7)'
                            }; %>
                            <div class="dropdown-user"
                                 onclick="switchProfile('<%= m._id %>')"
                                 style="cursor:pointer">
                                <div class="user-avatar"
                                     style="background:<%= colors[m.themeColor] || colors.purple %>">
                                    <%= m.full_name[0].toUpperCase() %>
                                </div>
                                <div class="user-info">
                                    <span class="user-name"><%= m.full_name %></span>
                                    <span class="user-role"><%= m.relationship %></span>
                                </div>
                                <div class="status-icon <%= (typeof activeMemberId !== 'undefined' && activeMemberId && activeMemberId.toString() === m._id.toString()) ? '' : 'unchecked' %>">✔</div>
                            </div>
                          <% }); %>
                        <% } %>

                        <div class="dropdown-divider"></div>

                        <a href="/add-members/<%= user._id %>" class="manage-link">
                            <img src="/public/img/icon/Settings-purple.png" alt="" class="manage-icon">
                            Manage Family Members
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <% }else{ %>
            <div class="landing-top-header">
                <a href="/" class="logo">Meditrace</a>
                <div class="auth-actions">
                    <a href="/login" class="link-login">Войти</a>
                    <a href="/regester" class="btn btn-register">Регистрация</a>
                </div>
            </div>
            <% } %>

</header>
<script>
function switchProfile(memberId) {
  const url = new URL(window.location.href);
  if (memberId) {
    url.searchParams.set('member', memberId);
  } else {
    url.searchParams.delete('member');
  }
  window.location.href = url.toString();
}
</script>